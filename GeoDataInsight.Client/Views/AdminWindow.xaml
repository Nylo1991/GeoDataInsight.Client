<Window x:Class="GeoDataInsight.Client.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciador de Banco de Dados" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI" Background="#F3F4F6">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Painel Administrativo" FontSize="24" FontWeight="Black" Foreground="#111827"/>
            <TextBlock Text="Gerencie os registros salvos no Firebase" FontSize="14" Foreground="#6B7280" Margin="0,4,0,16"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding TodosRegistros}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" Background="#FFFFFF"
                  RowBackground="#FFFFFF" AlternatingRowBackground="#F9FAFB"
                  BorderBrush="#E5E7EB" BorderThickness="1" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB">
            <DataGrid.Columns>
                <DataGridTextColumn Header="CEP" Binding="{Binding Cep}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Logradouro" Binding="{Binding Logradouro}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Data" Binding="{Binding Timestamp, StringFormat='dd/MM/yyyy HH:mm'}" Width="130" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>