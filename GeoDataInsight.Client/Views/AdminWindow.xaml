<Window x:Class="GeoDataInsight.Client.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GeoData Insight - Admin" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI" Background="#F8FAFC">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="FilterCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Sistema de Gestão de Dados" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Gerenciamento avançado de histórico e exclusão em lote" FontSize="14" Foreground="#94A3B8"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource FilterCard}">
            <StackPanel Orientation="Horizontal">
                <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Status dos Filtros" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <CheckBox Content="Ativar Filtros" IsChecked="{Binding FiltrosAtivos}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Buscar por ID" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox Width="120" Text="{Binding FiltroId, UpdateSourceTrigger=PropertyChanged}" Padding="8,5" Background="#F1F5F9" BorderThickness="0"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="CEP" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox Width="120" Text="{Binding FiltroCep, UpdateSourceTrigger=PropertyChanged}" Padding="8,5" Background="#F1F5F9" BorderThickness="0"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Data da Busca" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding FiltroData}" Width="150" Padding="5"/>
                </StackPanel>

                <Button Command="{Binding LimparFiltrosCommand}" Content="Limpar Filtros" 
                        Background="Transparent" BorderBrush="#CBD5E1" Foreground="#64748B"
                        Padding="15,0" Margin="10,15,0,0" Height="35"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="10">
            <Grid>
                <DataGrid ItemsSource="{Binding TodosRegistros}" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                        </DataGridCheckBoxColumn>

                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="CEP" Binding="{Binding Cep}" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="LOGRADOURO" Binding="{Binding Logradouro}" Width="*" IsReadOnly="True"/>

                        <DataGridTemplateColumn Header="DATA E HORA" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='dd MMM yyyy - HH:mm'}" 
                                               VerticalAlignment="Center" Foreground="#475569"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                            Visibility="{Binding MostrarAvisoVazio, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Nenhum registro encontrado" FontSize="20" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                    <TextBlock Text="Tente mudar os filtros ou verifique se o banco possui dados." FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Command="{Binding SelecionarTodosCommand}" Content="Selecionar Todos" 
                        Background="#E2E8F0" Foreground="#475569" Padding="15,8" BorderThickness="0" Margin="0,0,10,0"/>
                <Button Command="{Binding CarregarDadosCommand}" Content="🔄 Atualizar Banco" 
                        Background="#E2E8F0" Foreground="#475569" Padding="15,8" BorderThickness="0"/>
            </StackPanel>

            <Button Command="{Binding DeletarSelecionadosCommand}" HorizontalAlignment="Right" 
                    Background="#EF4444" Foreground="White" Padding="25,10" FontWeight="Bold" BorderThickness="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🗑️ EXCLUIR REGISTROS SELECIONADOS" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>