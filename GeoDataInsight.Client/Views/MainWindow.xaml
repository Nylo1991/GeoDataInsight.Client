<Window x:Class="GeoDataInsight.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GeoData Insight - Squad 1" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBox Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}" Width="400" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
            <Button Command="{Binding BuscarCommand}" Content="Buscar Local" Width="100" Height="30" Background="#2196F3" Foreground="White"/>
        </StackPanel>

        <GroupBox Header="Informações Geográficas" Grid.Row="1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Logradouro:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ResultadoAtual.Logradouro}" Margin="0,0,0,5" TextWrapping="Wrap"/>

                    <TextBlock Text="Número:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ResultadoAtual.Numero}" Margin="0,0,0,5"/>

                    <TextBlock Text="Bairro:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ResultadoAtual.Bairro}" Margin="0,0,0,5"/>

                    <TextBlock Text="CEP:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ResultadoAtual.Cep}" Margin="0,0,0,5"/>

                    <TextBlock Text="Latitude:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ResultadoAtual.Latitude}" Margin="0,0,0,5"/>

                    <TextBlock Text="Longitude:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ResultadoAtual.Longitude}" Margin="0,0,0,10"/>
                </StackPanel>

                <Border Grid.Column="1" BorderBrush="#DDDDDD" BorderThickness="1" Background="#EEEEEE" Margin="10,0,0,0">
                    <Image Source="{Binding MapImageUrl}" Stretch="Uniform" ToolTip="Mapa gerado pelo OpenStreetMap"/>
                </Border>
            </Grid>
        </GroupBox>

        <StatusBar Grid.Row="2" Background="#F0F0F0">
            <TextBlock Text="{Binding StatusMensagem}" Foreground="DimGray" FontWeight="Bold"/>
        </StatusBar>
    </Grid>
</Window>