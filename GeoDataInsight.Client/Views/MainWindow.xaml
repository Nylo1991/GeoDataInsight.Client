<Window x:Class="GeoDataInsight.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        Title="GeoData Insight - Squad 1" Height="600" Width="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#F8F8F8" Margin="5">
            <StackPanel Margin="10">
                <TextBlock Text="Localizador GeoData" FontSize="18" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,15"/>

                <TextBlock Text="Endereço ou Local:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtBusca" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,5"/>

                <Button x:Name="btnBuscar" Content="PESQUISAR" Height="35" 
                        Background="#2196F3" Foreground="White" FontWeight="Bold" Click="btnBuscar_Click"/>

                <Separator Margin="0,15"/>

                <TextBlock Text="Resultados da Busca:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListBox x:Name="lstResultados" Height="200" 
                         ItemsSource="{Binding Resultados}" 
                         SelectedItem="{Binding Selecionado}"
                         SelectionChanged="lstResultados_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Logradouro}" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Bairro}" FontSize="11" Foreground="Gray"/>
                                <TextBlock Text="{Binding Cep}" FontSize="10" Foreground="DimGray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button x:Name="btnSalvarFirebase" Content="SALVAR NO FIREBASE" 
                        Margin="0,15,0,0" Height="40" Background="#4CAF50" Foreground="White"
                        FontWeight="Bold" Click="btnSalvarFirebase_Click"/>

                <TextBlock x:Name="txtStatus" Text="Pronto" Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="Gray"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <mapsui:MapControl x:Name="mapControl" />
        </Grid>
    </Grid>
</Window>