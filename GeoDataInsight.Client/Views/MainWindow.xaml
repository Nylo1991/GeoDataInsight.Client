<Window x:Class="GeoDataInsight.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        Title="GeoDataInsight - Inteligência Geográfica" 
        Height="768" Width="1366"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI" 
        Background="#F3F4F6">

    <Grid>
        <mapsui:MapControl x:Name="mapControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="0"/>

        <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="24" Width="48" Height="48" Panel.ZIndex="2"
                Background="White" Cursor="Hand" ToolTip="Painel de Administração"
                Command="{Binding AbrirPainelAdminCommand}">
            <Button.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15" Color="#000000" Direction="270"/>
            </Button.Effect>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="AdminBorder" Background="{TemplateBinding Background}" CornerRadius="24" 
                            BorderBrush="#E5E7EB" BorderThickness="1">
                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.98C19.47,12.66 19.5,12.34 19.5,12C19.5,11.66 19.47,11.34 19.43,11.02L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.65 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.65 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.02C4.53,11.34 4.5,11.66 4.5,12C4.5,12.34 4.53,12.66 4.57,12.98L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.35 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.35 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.98Z" 
                              Fill="#4B5563" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="AdminBorder" Property="Background" Value="#F9FAFB"/>
                            <Setter TargetName="AdminBorder" Property="BorderBrush" Value="#D1D5DB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Width="400" MaxHeight="720" 
                Margin="24" Background="#FFFFFFFF" CornerRadius="20" Panel.ZIndex="1"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.12" Color="#000000" Direction="270"/>
            </Border.Effect>

            <Grid Margin="0,24,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,0,24,20">
                    <TextBlock Text="GeoDataInsight" FontSize="24" FontWeight="Black" Foreground="#111827"/>
                    <TextBlock Text="Inteligência Geográfica Global" FontSize="14" Foreground="#6B7280" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="24,0,24,0">
                    <Border x:Name="SearchBorder" Background="#F9FAFB" CornerRadius="24" Height="48" 
                            BorderBrush="#D1D5DB" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.05" Color="#000000" Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding AbrirHistoricoCommand}" 
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" 
                                    ToolTip="Ver histórico de buscas" Margin="8,0,0,0" Width="40">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="HistBorder" Background="Transparent" CornerRadius="20">
                                            <Path Data="M13,3A9,9 0 0,0 4,12H1L4.89,15.89L8.79,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3M12,8V13L16.28,15.54L17,14.33L13.5,12.25V8H12Z" 
                                                  Fill="#9CA3AF" Width="20" Height="20" Stretch="Uniform"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HistBorder" Property="Background" Value="#E5E7EB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBox Grid.Column="1" Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}" 
                                     BorderThickness="0" Background="Transparent" FontSize="15" Margin="8,0,8,0"
                                     VerticalContentAlignment="Center" Foreground="#111827">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding BuscarCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Grid.Column="2" Command="{Binding BuscarCommand}" 
                                    Background="#3B82F6" Foreground="White" BorderThickness="0" 
                                    Width="40" Height="40" Cursor="Hand" Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="20">
                                            <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                                                  Fill="White" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <ListBox Grid.Row="2" ItemsSource="{Binding Resultados}" SelectedItem="{Binding Selecionado}" 
                         BorderThickness="0" Background="Transparent" Margin="24,20,24,0" 
                         ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemBorder" Background="#FFFFFF" CornerRadius="12" Padding="16" 
                                    BorderBrush="#E5E7EB" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000000"/>
                                </Border.Effect>

                                <StackPanel>
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Path Grid.Column="0" Data="M12,2C15.86,2 19,5.13 19,9C19,14.25 12,22 12,22C12,22 5,14.25 5,9A7,7 0 0,1 12,2M12,4A5,5 0 0,0 7,9C7,12.05 10.35,17.43 12,19.85C13.65,17.43 17,12.05 17,9A5,5 0 0,0 12,4M12,6.5A2.5,2.5 0 0,1 14.5,9A2.5,2.5 0 0,1 12,11.5A2.5,2.5 0 0,1 9.5,9A2.5,2.5 0 0,1 12,6.5Z" 
                                              Fill="#EF4444" Width="20" Height="24" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Logradouro}" FontWeight="Bold" FontSize="15" Foreground="#111827" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Bairro}" FontSize="13" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel x:Name="DetailsPanel" Visibility="Collapsed" Margin="0,16,0,0">
                                        <Separator Background="#F3F4F6" Margin="0,0,0,16"/>

                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,10,0">
                                                <TextBlock Text="CÓD. POSTAL / REF" FontSize="10" FontWeight="Black" Foreground="#9CA3AF" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Cep}" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,10"/>

                                                <TextBlock Text="NÚMERO" FontSize="10" FontWeight="Black" Foreground="#9CA3AF" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Numero}" Margin="0,0,0,10" Foreground="#374151" FontWeight="Medium"/>
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="COORDENADAS" FontSize="10" FontWeight="Black" Foreground="#9CA3AF" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Latitude, StringFormat='Lat: \{0\}'}" FontSize="11" Foreground="#374151"/>
                                                <TextBlock Text="{Binding Longitude, StringFormat='Long: \{0\}'}" FontSize="11" Foreground="#374151" Margin="0,0,0,10"/>

                                                <TextBlock Text="DATA" FontSize="10" FontWeight="Black" Foreground="#9CA3AF" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='\{0:dd/MM/yyyy HH:mm\}'}" FontSize="11" Foreground="#374151"/>
                                            </StackPanel>
                                        </UniformGrid>

                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Id, StringFormat='ID: \{0\}'}" FontSize="9" Foreground="#9CA3AF" FontWeight="Bold"/>
                                            </Border>

                                            <Button Grid.Column="1" 
                                                    Command="{Binding DataContext.DeletarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#EF4444" Foreground="White" BorderThickness="0" 
                                                    Padding="12,6" Cursor="Hand" FontWeight="Bold" FontSize="12" Margin="0,0,8,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="DelBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                                                      Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                                                <TextBlock Text="Deletar"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="DelBorder" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Grid.Column="2" 
                                                    Command="{Binding DataContext.SalvarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#10B981" Foreground="White" BorderThickness="0" 
                                                    Padding="12,6" Cursor="Hand" FontWeight="Bold" FontSize="12">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="SaveBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                                <Path Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" 
                                                                      Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                                                <TextBlock Text="Salvar no Banco"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="SaveBorder" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#F9FAFB"/>
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#D1D5DB"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="DetailsPanel" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#3B82F6"/>
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#FAFBFF"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>