<Window x:Class="GeoDataInsight.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        Title="GeoDataInsight - Gerenciador de Localização" Height="600" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="Buscar Localização" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <DockPanel Margin="0,0,0,10">
                <Button x:Name="btnBuscar" Content="Buscar" Width="80" DockPanel.Dock="Right" Click="btnBuscar_Click"/>
                <TextBox x:Name="txtBusca" Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0"/>
            </DockPanel>

            <TextBlock Text="Resultados:" FontWeight="SemiBold" Margin="0,5"/>
            <ListBox x:Name="lstResultados" Height="150" 
                     ItemsSource="{Binding Resultados}" 
                     SelectedItem="{Binding Selecionado}"
                     SelectionChanged="lstResultados_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Logradouro}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Separator Margin="0,15"/>

            <TextBlock Text="Detalhes da Seleção" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="ID:"/>
            <TextBox Text="{Binding Selecionado.Id, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,5"/>

            <TextBlock Text="Logradouro:"/>
            <TextBox Text="{Binding Selecionado.Logradouro, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,5"/>

            <TextBlock Text="Número:"/>
            <TextBox Text="{Binding Selecionado.Numero, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,5"/>

            <TextBlock Text="Bairro:"/>
            <TextBox Text="{Binding Selecionado.Bairro, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,5"/>

            <TextBlock Text="CEP:"/>
            <TextBox Text="{Binding Selecionado.Cep, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,5"/>

            <TextBlock Text="Latitude:"/>
            <TextBox Text="{Binding Selecionado.Latitude, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,5"/>

            <TextBlock Text="Longitude:"/>
            <TextBox Text="{Binding Selecionado.Longitude, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,5"/>

            <Button x:Name="btnSalvarFirebase" Content="Salvar no Histórico" Margin="0,10,0,0" Click="btnSalvarFirebase_Click"/>

            <TextBlock Text="{Binding StatusMensagem}" Foreground="Gray" Margin="0,10"/>
        </StackPanel>

        <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1,0,0,0">
            <mapsui:MapControl x:Name="mapControl"/>
        </Border>
    </Grid>
</Window>